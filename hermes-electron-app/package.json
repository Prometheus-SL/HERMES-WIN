{
  "name": "hermes-electron-app",
  "version": "1.0.0",
  "description": "HERMES cross-platform Electron UI + Node agent",
  "main": "src/main/main.ts",
  "scripts": {
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "start:agent": "node src/service/agent.js",
    "service:install": "node -e \"require('./src/service/serviceWindows').installService()\"",
    "service:uninstall": "node -e \"require('./src/service/serviceWindows').uninstallService()\"",
  "build:native": "powershell -Command \"cd native\\win_volume; cargo build --release; Copy-Item target\\release\\win_volume.dll -Destination ..\\..\\src\\native -Force -ErrorAction SilentlyContinue\"",
    "build": "electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/hermes-electron-app.git"
  },
  "keywords": [
    "electron",
    "cross-platform",
    "native-bindings"
  ],
  "author": "Your Name",
  "license": "GPL-2.0-or-later",
  "dependencies": {
    "electron": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2",
    "axios": "^1.4.0",
    "keytar": "^8.0.0",
    "cross-env": "^7.0.3",
    "node-windows": "^0.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.0",
    "electron-builder": "^25.2.0",
    "@types/node": "^20.5.1",
    "@types/react": "^18.2.24",
    "@types/react-dom": "^18.2.8"
  },
  "build": {
    "appId": "com.yourname.hermes",
    "files": [
      "dist/**/*",
      "src/**/*",
      "package.json",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "src/native",
        "to": "native"
      }
    ]
  }
}
