{
  "manifest_version": 3,
  "name": "Hermes Media Bridge",
  "version": "1.0.0",
  "description": "Bridge browser media sessions to Hermes over localhost.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://*.youtube.com/*",
    "https://youtu.be/*",
    "https://www.twitch.tv/*",
    "https://m.twitch.tv/*",
    "https://soundcloud.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtu.be/*",
        "https://www.twitch.tv/*",
        "https://m.twitch.tv/*",
        "https://soundcloud.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
