{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.prometeo.hermes",
  "productName": "Prometeo Hermes",
  "artifactName": "HERMES-${os}-${version}-${arch}.${ext}",
  "copyright": "Copyright (c) Prometeo SL",
  "directories": {
    "app": "dist/app",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "extensions/**/*",
    "src/native/**/*.node",
    "node_modules/keytar/**/*",
    "node_modules/node-windows/**/*",
    "!src/service/daemon/**/*",
    "!src/service/daemon/*.log",
    "package.json",
    "LICENSE"
  ],
  "npmRebuild": false,
  "asar": true,
  "asarUnpack": [
    "dist/service/**/*.js",
    "extensions/**/*",
    "src/native/**/*.node"
    ,
    "node_modules/keytar/**/*",
    "node_modules/node-windows/**/*"
  ],
  "win": {
    "artifactName": "HERMES-windows-${version}-${arch}.${ext}",
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "artifactName": "HERMES-windows-Setup-${version}.${ext}",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "linux": {
    "artifactName": "HERMES-linux-${version}-${arch}.${ext}",
    "category": "Utility",
    "maintainer": "Prometeo <engineering@prometeo.local>",
    "target": [
      {
        "target": "AppImage",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "deb",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "mac": {
    "artifactName": "HERMES-macos-${version}-${arch}.${ext}",
    "category": "public.app-category.utilities",
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "target": [
      "dmg",
      "zip"
    ]
  }
}
