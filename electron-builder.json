{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.prometheus.hermeswin",
  "productName": "Prometeo Hermes",
  "artifactName": "HERMES-WIN-${version}-${arch}.${ext}",
  "copyright": "Copyright (c) Prometeo SL",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "src/service/**/*",
    "src/native/**/*.node",
    "!src/service/daemon/*.log",
    "package.json",
    "LICENSE"
  ],
  "npmRebuild": false,
  "asar": true,
  "asarUnpack": [
    "src/service/**/*.js",
    "src/native/**/*.node"
  ],
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "artifactName": "HERMES-WIN-Setup-${version}.${ext}",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
